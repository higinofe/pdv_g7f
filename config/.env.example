# Configurações do PDV — copiar para config/.env e editar conforme cada cliente
API_URL=https://exemplo.trycloudflare.com/api/pdv
API_TOKEN=substitua_pelo_token_real

PDV_ID=001
PDV_NOME=pdv_01

# Senha do administrador (para tela de configurações)
ADMIN_PASSWORD=trocar_em_producao

# Endpoints da API do ERP (caminhos relativos a API_URL)
ENDPOINT_PRODUTOS=/carga
ENDPOINT_OPERADORES=/operadores
ENDPOINT_OPERADOR_LOGIN=/operadores/login
ENDPOINT_VENDAS=/venda
ENDPOINT_CUPOM=/cupom-fiscal

# Timeout em segundos para chamadas HTTP ao ERP
HTTP_TIMEOUT=30

# Slideshow da tela de caixa fechado (ms entre slides)
SLIDES_INTERVALO_MS=6000
